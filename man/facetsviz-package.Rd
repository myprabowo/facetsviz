\name{facetsviz-package}
\alias{facetsviz-package}
\title{Parse and visualize FACETS output files}
\description{
The \pkg{facetsviz} package parses FACETS \code{.out} files and renders common
multi-facet Rasch measurement plots, including Wright maps, severity
distributions, criterion diagnostics, rating-scale diagnostics, and unexpected
response summaries.
}
\section{Core functions}{
\itemize{
  \item \code{read_facets_out()}
  \item \code{render_facets_plots()}
  \item \code{render_facets_batch()}
  \item \code{run_facets_app()}
}
}
